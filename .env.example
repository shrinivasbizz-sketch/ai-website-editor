# ── URLs (set these when deployed) ───────────────────────────────────────────
# Where the Python agent lives (Railway / Render / Fly.io / localhost)
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
AGENT_BACKEND_URL=http://localhost:8000

# Public URL of the Next.js editor (Vercel / localhost)
NEXT_PUBLIC_EDITOR_URL=http://localhost:3000

# ── AI Provider (OPTIONAL — only needed for server-side fallback) ─────────────
# Users normally configure their own key in the browser Settings panel.
# Set one of these only if you want a shared default key for users who skip setup.

# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
